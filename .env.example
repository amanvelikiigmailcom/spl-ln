# Siplinx AI — переменные окружения
# Скопируй этот файл в .env.local и заполни реальными значениями

# Cloudflare Pages
CF_API_TOKEN=
CF_ACCOUNT_ID=

# Аналитика (опционально)
PUBLIC_GOOGLE_ANALYTICS_ID=

# PostHog (публичный write-only ключ, безопасно хранить здесь)
PUBLIC_POSTHOG_KEY=phc_qnmK7KqRbUvbZy3R4YBjWnZ2RrDTWmhHzW4CFSpdJjMt
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# SE Ranking API (для выгрузки ключевых слов)
