---

---

<span class="flex items-center">
  <svg
    width="42"
    height="46"
    viewBox="0 0 200 222"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label="Siplinx AI"
    style="overflow: visible;"
    class="sl-logo"
  >
    <defs>
      <!-- Violet/indigo gradient - bottom ribbon (back layer) -->
      <linearGradient id="sl-v" x1="48" y1="104" x2="166" y2="220" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="#6D28D9"></stop>
        <stop offset="45%" stop-color="#7C3AED"></stop>
        <stop offset="100%" stop-color="#4F46E5"></stop>
      </linearGradient>
      <!-- Cyan→blue gradient - top ribbon (front layer) -->
      <linearGradient id="sl-b" x1="40" y1="8" x2="156" y2="124" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="#93C5FD"></stop>
        <stop offset="28%" stop-color="#3B82F6"></stop>
        <stop offset="70%" stop-color="#2563EB"></stop>
        <stop offset="100%" stop-color="#1D4ED8"></stop>
      </linearGradient>
      <!-- Glossy sheen overlay on the top ribbon -->
      <linearGradient id="sl-gloss-b" x1="60" y1="14" x2="100" y2="96" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="#FFFFFF" stop-opacity="0.85"></stop>
        <stop offset="45%" stop-color="#FFFFFF" stop-opacity="0.18"></stop>
        <stop offset="100%" stop-color="#FFFFFF" stop-opacity="0"></stop>
      </linearGradient>
      <!-- Glossy sheen overlay on the bottom ribbon -->
      <linearGradient id="sl-gloss-v" x1="150" y1="128" x2="110" y2="210" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="#E9D5FF" stop-opacity="0.8"></stop>
        <stop offset="50%" stop-color="#C4B5FD" stop-opacity="0.15"></stop>
        <stop offset="100%" stop-color="#FFFFFF" stop-opacity="0"></stop>
      </linearGradient>
      <!-- White rim highlight along the lit upper edge -->
      <linearGradient id="sl-rim" x1="44" y1="10" x2="92" y2="80" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="#FFFFFF" stop-opacity="1"></stop>
        <stop offset="55%" stop-color="#FFFFFF" stop-opacity="0.45"></stop>
        <stop offset="100%" stop-color="#FFFFFF" stop-opacity="0"></stop>
      </linearGradient>
      <!-- Soft drop shadow under the mark -->
      <filter id="sl-shadow" x="-40%" y="-25%" width="180%" height="170%">
        <feDropShadow dx="0" dy="6" stdDeviation="7" flood-color="#4338CA" flood-opacity="0.30"></feDropShadow>
      </filter>
      <!-- Soft glow for the crossover seam -->
      <filter id="sl-glow" x="-80%" y="-80%" width="260%" height="260%">
        <feGaussianBlur in="SourceGraphic" stdDeviation="6" result="b"></feGaussianBlur>
        <feMerge><feMergeNode in="b"></feMergeNode><feMergeNode in="SourceGraphic"></feMergeNode></feMerge>
      </filter>
    </defs>

    <g filter="url(#sl-shadow)">
      <!-- ── Bottom half / violet ribbon (back layer) ─────────────── -->
      <path
        d="M52 168 C50 194 68 214 96 214 L118 214 C146 214 158 196 158 172 C158 150 145 135 120 126 L78 110"
        stroke="url(#sl-v)"
        stroke-width="42"
        stroke-linecap="round"
        fill="none"></path>
      <!-- gloss on bottom ribbon -->
      <path
        d="M52 168 C50 194 68 214 96 214 L118 214 C146 214 158 196 158 172 C158 150 145 135 120 126 L78 110"
        stroke="url(#sl-gloss-v)"
        stroke-width="42"
        stroke-linecap="round"
        fill="none"></path>

      <!-- ── Top half / blue ribbon (front layer - covers crossover) ─ -->
      <path
        d="M148 52 C148 27 131 10 106 10 L83 10 C55 10 44 28 44 54 C44 78 57 94 83 104 L124 120"
        stroke="url(#sl-b)"
        stroke-width="42"
        stroke-linecap="round"
        fill="none"></path>
      <!-- gloss on top ribbon -->
      <path
        d="M148 52 C148 27 131 10 106 10 L83 10 C55 10 44 28 44 54 C44 78 57 94 83 104 L124 120"
        stroke="url(#sl-gloss-b)"
        stroke-width="42"
        stroke-linecap="round"
        fill="none"></path>

      <!-- ── Outer-edge rim light (the lit upper edge of blue ribbon) ─ -->
      <path
        d="M148 52 C148 27 131 10 106 10 L83 10 C55 10 44 28 44 54 C44 69 52 82 66 91"
        stroke="url(#sl-rim)"
        stroke-width="9"
        stroke-linecap="round"
        fill="none"></path>

      <!-- ── Bright seam glow at the crossover point ───────────────── -->
      <ellipse
        cx="101"
        cy="115"
        rx="5"
        ry="11"
        fill="white"
        opacity="0.8"
        transform="rotate(-28 101 115)"
        filter="url(#sl-glow)"></ellipse>
      <ellipse cx="101" cy="115" rx="2.5" ry="5.5" fill="white" opacity="1" transform="rotate(-28 101 115)"></ellipse>
    </g>
  </svg>
</span>
