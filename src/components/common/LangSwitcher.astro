---
const currentPath = Astro.url.pathname;
const isRu = currentPath.startsWith('/ru');
const enPath = isRu ? currentPath.replace(/^\/ru/, '') || '/' : currentPath;

// Slugs that have RU article versions
const ruArticleSlugs = new Set([
  '/granola-alternative-siplinx/',
  '/fireflies-alternative/',
  '/google-meet-notes/',
  '/how-to-take-meeting-notes/',
  '/mac-meeting-notes-app/',
  '/meeting-action-items/',
  '/meeting-minutes-template/',
  '/meeting-summary-generator/',
  '/offline-meeting-recorder/',
  '/otter-ai-alternative/',
  '/real-time-meeting-transcription/',
  '/sales-call-notes/',
  '/teams-meeting-notes/',
  '/windows-meeting-recorder/',
  '/zoom-meeting-notes/',
  '/productive-meetings-ai-strategies/',
  '/private-ai-tools-local-processing/',
  '/how-to-write-meeting-summaries-ai/',
  '/best-ai-meeting-assistant-2025/',
  '/ai-meeting-notes-complete-guide/',
  '/speech-to-text-app-meetings/',
  '/read-ai-alternative/',
  '/ai-note-taker-sales-calls/',
  '/tldv-alternative/',
  '/fathom-alternative/',
]);

// Paths that have explicit RU static pages
const hasRuStaticPage =
  currentPath === '/' ||
  currentPath.startsWith('/ru') ||
  currentPath.startsWith('/about') ||
  currentPath.startsWith('/pricing') ||
  currentPath.startsWith('/download') ||
  currentPath.startsWith('/welcome') ||
  currentPath.startsWith('/get') ||
  currentPath.startsWith('/security') ||
  currentPath.startsWith('/privacy') ||
  currentPath.startsWith('/terms') ||
  currentPath.startsWith('/careers') ||
  currentPath.startsWith('/help') ||
  currentPath.startsWith('/contact') ||
  currentPath.startsWith('/press') ||
  currentPath.startsWith('/authors') ||
  ruArticleSlugs.has(currentPath);

const ruPath = isRu ? currentPath : hasRuStaticPage ? `/ru${currentPath === '/' ? '/' : currentPath}` : '/ru/blog/';
---

<div class="flex items-center gap-0.5 ml-2">
  <a
    href={enPath}
    data-lang-switch="en"
    class:list={[
      'px-2 py-1 text-xs font-semibold rounded transition-colors',
      !isRu ? 'bg-blue-600 text-white' : 'text-muted dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400',
    ]}>EN</a
  >
  <a
    href={ruPath}
    data-lang-switch="ru"
    class:list={[
      'px-2 py-1 text-xs font-semibold rounded transition-colors',
      isRu ? 'bg-blue-600 text-white' : 'text-muted dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400',
    ]}>RU</a
  >
</div>

<script>
  document.querySelectorAll('[data-lang-switch]').forEach((link) => {
    link.addEventListener('click', () => {
      const lang = (link as HTMLElement).getAttribute('data-lang-switch');
      if (lang) localStorage.setItem('siplinx-lang', lang);
    });
  });
</script>
