---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(59 130 246);
    --aw-color-secondary: rgb(37 99 235);
    --aw-color-accent: rgb(124 58 237);

    --aw-color-text-heading: rgb(9 9 11);
    --aw-color-text-default: rgb(24 24 27);
    --aw-color-text-muted: rgb(63 63 70);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(6 5 18);

    ::selection {
      background-color: rgb(196 181 253);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(96 165 250);
    --aw-color-secondary: rgb(59 130 246);
    --aw-color-accent: rgb(167 139 250);

    --aw-color-text-heading: rgb(250 250 250);
    --aw-color-text-default: rgb(228 228 231);
    --aw-color-text-muted: rgb(161 161 170);
    --aw-color-bg-page: rgb(6 5 18);

    ::selection {
      background-color: rgb(88 28 135);
      color: white;
    }
  }
</style>
