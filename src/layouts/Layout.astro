      (function () {
        var el = document.getElementById('posthog-init');
        posthog.init(el.dataset.key, {
          api_host: el.dataset.host,
          defaults: '2026-05-30',
          person_profiles: 'identified_only',
        });
      })();
    </script>

    <!-- Microsoft Clarity - is:inline so Astro doesn't bundle/transform it -->
    <script is:inline>
      /* eslint-disable prefer-rest-params */
      (function (c, l, a, r, i, t, y) {
        c[a] =
          c[a] ||
          function () {
            (c[a].q = c[a].q || []).push(arguments);
          };
        t = l.createElement(r);
        t.async = 1;
        t.src = 'https://www.clarity.ms/tag/' + i;
        y = l.getElementsByTagName(r)[0];
        y.parentNode.insertBefore(t, y);
      })(window, document, 'clarity', 'script', 'xbp2gn6ew9');
      /* eslint-enable prefer-rest-params */
    </script>

    <!-- Meta Pixel - is:inline so Astro doesn't bundle/transform it -->
    <script is:inline>
      /* eslint-disable prefer-rest-params */
      !(function (f, b, e, v, n, t, s) {
        if (f.fbq) return;
        n = f.fbq = function () {
          n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments);
        };
        if (!f._fbq) f._fbq = n;
        n.push = n;
        n.loaded = !0;
        n.version = '2.0';
        n.queue = [];
        t = b.createElement(e);
        t.async = !0;
        t.src = v;
        s = b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t, s);
      })(window, document, 'script', 'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '893895443283489');
      fbq('track', 'PageView');
      /* eslint-enable prefer-rest-params */
    </script>
  </head>

  <body class="antialiased text-default bg-page tracking-tight">
    <noscript>
      <img
        height="1"
        width="1"
        style="display:none"
        src="https://www.facebook.com/tr?id=893895443283489&ev=PageView&noscript=1"
      />
    </noscript>
    <slot />

    <BasicScripts />

    <!-- Scroll reveal for custom pages -->
    <script>
      function initReveal() {
        const els = document.querySelectorAll<HTMLElement>('.reveal, .reveal-left, .reveal-scale');
        if (!els.length) return;
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry, idx) => {
              if (entry.isIntersecting) {
                const el = entry.target as HTMLElement;
                const delay = el.dataset.delay ? parseInt(el.dataset.delay) : idx * 80;
                setTimeout(() => el.classList.add('revealed'), delay);
                io.unobserve(el);
              }
            });
          },
          { threshold: 0.1 }
        );
        els.forEach((el) => io.observe(el));
      }
      initReveal();
      document.addEventListener('astro:after-swap', initReveal);
    </script>

    <!-- PostHog event tracking -->
    <script>
      type PH = { capture: (e: string, p?: Record<string, unknown>) => void };
      function phCapture(event: string, props?: Record<string, unknown>) {
        const ph = (window as unknown as Record<string, unknown>).posthog as PH | undefined;
        if (ph?.capture) ph.capture(event, props);
      }
      // Expose globally so page-level scripts can use it before posthog loads
      (window as unknown as Record<string, unknown>).__ph = phCapture;

      function phPageView() {
        const path = window.location.pathname;
        const lang = path.startsWith('/ru') ? 'ru' : 'en';
        phCapture('$pageview', { path, lang });
      }

      function phClickHandler(e: MouseEvent) {
        const target = (e.target as HTMLElement).closest('a, button');
        if (!target) return;
        const href = (target as HTMLAnchorElement).href || '';
        const text = target.textContent?.trim().toLowerCase() || '';
        const cls = target.className || '';
        const path = window.location.pathname;
        const lang = path.startsWith('/ru') ? 'ru' : 'en';

        // Detect download / auth buttons
        if (href.includes('siplinx-ai.vercel.app') || href.includes('/download')) {
          let loc = 'other';
          if (cls.includes('hero-btn')) loc = 'hero';
          else if (cls.includes('cta-btn')) loc = 'cta';
          else if (cls.includes('header-dl-btn')) loc = 'header';
          else if (path.includes('/get')) loc = 'get_page';
          else if (path.includes('/download')) loc = 'download_page';

          const isWin = cls.includes('win') || text.includes('windows') || text.includes('exe');
          const variant = href.includes('variant=direct') ? 'direct' : 'free_trial';

          // Generic download click (backward compat)
          phCapture('download_click', { location: loc, os: isWin ? 'windows' : 'mac', lang, page: path, variant });
        } else if (text.includes('trial7') || cls.includes('promo')) {
          phCapture('promo_copy', { lang });
        } else if ((target as HTMLElement).dataset.langSwitch) {
          phCapture('lang_switch', { to: (target as HTMLElement).dataset.langSwitch });
        } else if (href.includes('/pricing') || text.includes('pricing') || text.includes('цены')) {
          phCapture('pricing_click', { lang, from: path });
        }

        // Blog article CTA
        const articleMatch = path.match(/\/(?:ru\/)?([^/]+)\/?$/);
        if (articleMatch && href.includes('siplinx-ai.vercel.app') && !path.includes('/blog') && document.querySelector('article')) {
          phCapture('blog_cta_click', { slug: articleMatch[1], lang, page: path });
        }
      }

      if (!(window as unknown as Record<string, unknown>).__phInit) {
        (window as unknown as Record<string, unknown>).__phInit = true;
        document.addEventListener('click', phClickHandler);
      }

      document.addEventListener('astro:page-load', phPageView);
    </script>

    <!-- Clarity event tracking -->
    <script>
      type ClarityFn = (method: string, ...args: string[]) => void;

      function clarityFire(event: string) {
        const w = window as unknown as Record<string, unknown>;
        if (typeof w.clarity === 'function') {
          (w.clarity as ClarityFn)('event', event);
        }
      }

      function clarityPageView() {
        const path = window.location.pathname;
        if (path === '/' || path === '/ru' || path === '/ru/') clarityFire('page_home');
        else if (path.includes('/pricing')) clarityFire('page_pricing');
        else if (path.includes('/download')) clarityFire('page_download');
        else if (path.includes('/help')) clarityFire('page_help');
        else if (path.includes('/blog')) clarityFire('page_blog');
        else if (path.includes('/about')) clarityFire('page_about');
        else if (path.includes('/contact')) clarityFire('page_contact');
      }

      function clarityClickHandler(e: MouseEvent) {
        const target = (e.target as HTMLElement).closest('a, button');
        if (!target) return;
        const href = (target as HTMLAnchorElement).href || '';
        const text = target.textContent?.trim().toLowerCase() || '';
        const cls = target.className || '';

        if (href.includes('/download') || text.includes('download') || text.includes('скачать')) {
          if (cls.includes('hero-btn') || cls.includes('hero')) clarityFire('click_download_hero');
          else if (cls.includes('cta-btn') || cls.includes('cta')) clarityFire('click_download_cta');
          else clarityFire('click_download_nav');
        } else if (
          href.includes('/pricing') ||
          text.includes('pricing') ||
          text.includes('цены') ||
          text.includes('тарифы')
        ) {
          clarityFire('click_pricing_nav');
        } else if (href.includes('/help') || text.includes('help center') || text.includes('центр помощи')) {
          clarityFire('click_help_center');
        } else if (href.includes('/blog') || text.includes('blog') || text.includes('блог')) {
          clarityFire('click_blog');
        } else if (href.includes('/contact') || text.includes('contact') || text.includes('контакт')) {
          clarityFire('click_contact');
        } else if (
          text.includes('get started') ||
          text.includes('buy') ||
          text.includes('choose') ||
          text.includes('начать') ||
          text.includes('выбрать') ||
          text.includes('купить')
        ) {
          if (text.includes('starter') || text.includes('monthly') || text.includes('месяц'))
            clarityFire('click_pricing_starter');
          else if (text.includes('pro') || text.includes('annual') || text.includes('год'))
            clarityFire('click_pricing_pro');
          else clarityFire('click_pricing_cta');
        } else if (text.includes('telegram') || href.includes('t.me')) {
          clarityFire('click_telegram');
        }
      }

      // Attach click handler once; use astro:page-load to track SPA page views
      // Guard against double-registration across hot reloads
      if (!(window as unknown as Record<string, unknown>).__clarityInit) {
        (window as unknown as Record<string, unknown>).__clarityInit = true;
        document.addEventListener('click', clarityClickHandler);
      }

      // Fire page-view on every navigation (initial + View Transitions)
      document.addEventListener('astro:page-load', clarityPageView);
    </script>

    <script>
      (function () {
        const stored = localStorage.getItem('siplinx-lang');
        const path = window.location.pathname;
        const onRu = path.startsWith('/ru');
        if (!stored) {
          const bl = (navigator.language || '').toLowerCase();
          const wantRu = bl.startsWith('ru');
          localStorage.setItem('siplinx-lang', wantRu ? 'ru' : 'en');
          if (wantRu && !onRu) {
            window.location.replace('/ru' + (path === '/' ? '' : path));
          }
        } else if (stored === 'ru' && !onRu) {
          window.location.replace('/ru' + (path === '/' ? '' : path));
        } else if (stored === 'en' && onRu) {
          window.location.replace(path.replace(/^\/ru/, '') || '/');
        }
      })();
    </script>
  </body>
</html>
