---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Download Siplinx AI - Free Trial',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <HeroText
    tagline="Start free - no credit card"
    title="Download Siplinx AI"
    subtitle="Install in minutes. Local LLM + STT models set up automatically. Use code TRIAL7 to start 100% free."
  />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <!-- Single primary card - shown by OS detection -->
    <div id="download-primary" class="flex justify-center mb-6">
      <!-- Mac card (shown by default until JS runs) -->
      <div
        id="card-mac"
        class="w-full max-w-sm rounded-2xl border border-gray-200 dark:border-blue-900 bg-gradient-to-br from-gray-50 via-blue-50/30 to-violet-50/40 dark:from-[#0A0918] dark:via-blue-950/30 dark:to-violet-950/30 p-10 text-center shadow-xl ring-2 ring-blue-500 dark:ring-blue-400"
      >
        <div
          class="inline-flex items-center justify-center w-24 h-24 rounded-2xl bg-gradient-to-br from-gray-800 to-black mb-6 shadow-lg"
        >
          <Icon name="tabler:brand-apple" class="w-12 h-12 text-white" />
        </div>
        <h2 class="text-2xl font-bold mb-2 dark:text-white">Download for Mac</h2>
        <p class="text-muted dark:text-slate-400 mb-1">macOS 12 (Monterey) or later</p>
        <p class="text-sm text-muted dark:text-slate-500 mb-8">Apple Silicon &amp; Intel · ~85 MB</p>
        <a
          href="https://siplinx-ai.vercel.app/download"
          class="inline-flex items-center gap-2 w-full justify-center px-6 py-4 bg-gradient-to-r from-blue-600 to-violet-600 hover:from-blue-700 hover:to-violet-700 text-white font-bold rounded-xl transition-all duration-200 shadow-md hover:shadow-lg text-base"
        >
          <Icon name="tabler:download" class="w-5 h-5" />
          Download .dmg
        </a>
        <p class="text-xs text-muted dark:text-slate-500 mt-3">Free · Version 1.0.0</p>
      </div>

      <!-- Windows card (hidden until JS detects Windows) -->
      <div
        id="card-win"
        class="hidden w-full max-w-sm rounded-2xl border border-gray-200 dark:border-blue-900 bg-gradient-to-br from-gray-50 via-blue-50/30 to-cyan-50/40 dark:from-[#0A0918] dark:via-blue-950/30 dark:to-cyan-950/30 p-10 text-center shadow-xl ring-2 ring-blue-500 dark:ring-blue-400"
      >
        <div
          class="inline-flex items-center justify-center w-24 h-24 rounded-2xl bg-gradient-to-br from-blue-500 to-blue-700 mb-6 shadow-lg"
        >
          <Icon name="tabler:brand-windows" class="w-12 h-12 text-white" />
        </div>
        <h2 class="text-2xl font-bold mb-2 dark:text-white">Download for Windows</h2>
        <p class="text-muted dark:text-slate-400 mb-1">Windows 10 / 11 (64-bit)</p>
        <p class="text-sm text-muted dark:text-slate-500 mb-8">x64 · ~92 MB</p>
        <a
          href="https://siplinx-ai.vercel.app/download"
          class="inline-flex items-center gap-2 w-full justify-center px-6 py-4 bg-gradient-to-r from-blue-600 to-violet-600 hover:from-blue-700 hover:to-violet-700 text-white font-bold rounded-xl transition-all duration-200 shadow-md hover:shadow-lg text-base"
        >
          <Icon name="tabler:download" class="w-5 h-5" />
          Download .exe
        </a>
        <p class="text-xs text-muted dark:text-slate-500 mt-3">Free · Version 1.0.0</p>
      </div>
    </div>

    <!-- Secondary OS link -->
    <p id="os-alt-link" class="hidden text-center text-sm text-muted dark:text-slate-500 mb-16">
      Not on a Mac?
      <a
        id="os-alt-anchor"
        href="https://siplinx-ai.vercel.app/download"
        class="underline hover:text-blue-600 dark:hover:text-blue-400"
      >
        Download for Windows
      </a>
    </p>

    <!-- Feature highlights -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
      <div class="text-center p-6 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/10">
        <div
          class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-violet-600 mb-4"
        >
          <Icon name="tabler:shield-lock" class="w-6 h-6 text-white" />
        </div>
        <h3 class="font-bold mb-2 dark:text-white">100% Private</h3>
        <p class="text-sm text-muted dark:text-slate-400">
          All processing happens on your device. Nothing leaves your machine.
        </p>
      </div>
      <div class="text-center p-6 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/10">
        <div
          class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-violet-600 mb-4"
        >
          <Icon name="tabler:rocket" class="w-6 h-6 text-white" />
        </div>
        <h3 class="font-bold mb-2 dark:text-white">Instant Setup</h3>
        <p class="text-sm text-muted dark:text-slate-400">
          Install and start transcribing in under 2 minutes. No account needed.
        </p>
      </div>
      <div class="text-center p-6 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/10">
        <div
          class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-violet-600 mb-4"
        >
          <Icon name="tabler:refresh" class="w-6 h-6 text-white" />
        </div>
        <h3 class="font-bold mb-2 dark:text-white">Free Updates</h3>
        <p class="text-sm text-muted dark:text-slate-400">
          Automatic updates with new features and model improvements.
        </p>
      </div>
    </div>

    <!-- Promo code + trial note -->
    <div
      class="text-center p-8 rounded-2xl border border-blue-200 dark:border-blue-900 bg-gradient-to-br from-blue-50 to-violet-50 dark:from-blue-950/30 dark:to-violet-950/30"
    >
      <p class="text-sm font-medium text-muted dark:text-slate-400 mb-2">🎁 Your trial is completely free</p>
      <h3 class="text-xl font-bold mb-3 dark:text-white">Use promo code at checkout</h3>
      <span
        class="inline-block font-mono font-bold text-2xl tracking-widest px-6 py-2 rounded-xl bg-gradient-to-r from-blue-600 to-violet-600 text-white select-all mb-3"
      >
        TRIAL7
      </span>
      <p class="text-sm text-muted dark:text-slate-400 mb-4">100% discount · No credit card required</p>
      <a
        href="/pricing/"
        class="inline-flex items-center gap-1 bg-gradient-to-r from-blue-600 to-violet-600 bg-clip-text text-transparent font-semibold hover:underline"
      >
        View all plans →
      </a>
    </div>
  </div>

  <script>
    function detectOS(): 'mac' | 'windows' {
      // eslint-disable-next-line @typescript-eslint/no-explicit-any
      const uaData = (navigator as any).userAgentData;
      if (uaData?.platform) {
        const p = uaData.platform.toLowerCase();
        if (p.includes('win')) return 'windows';
      }
      const ua = navigator.userAgent.toLowerCase();
      const platform = (navigator.platform || '').toLowerCase();
      if (platform.includes('win') || ua.includes('windows nt') || ua.includes('win32') || ua.includes('win64'))
        return 'windows';
      return 'mac';
    }

    const os = detectOS();
    const cardMac = document.getElementById('card-mac');
    const cardWin = document.getElementById('card-win');
    const altLink = document.getElementById('os-alt-link');
    const altAnchor = document.getElementById('os-alt-anchor') as HTMLAnchorElement | null;

    if (os === 'windows') {
      cardMac?.classList.add('hidden');
      cardWin?.classList.remove('hidden');
      if (altLink && altAnchor) {
        altLink.classList.remove('hidden');
        altLink.childNodes[0].textContent = 'Not on Windows? ';
        altAnchor.textContent = 'Download for Mac';
      }
    } else {
      cardMac?.classList.remove('hidden');
      cardWin?.classList.add('hidden');
      if (altLink && altAnchor) {
        altLink.classList.remove('hidden');
        altLink.childNodes[0].textContent = 'Not on a Mac? ';
        altAnchor.textContent = 'Download for Windows';
      }
    }

    // Auth flow: Google → /welcome → download
    function handleDlClick(e: MouseEvent) {
      e.preventDefault();
      const redirect = encodeURIComponent('https://siplinx-ai.vercel.app/download');
      window.location.href = `https://siplinx-ai.vercel.app/web/start?redirect=${redirect}`;
    }
    document.querySelectorAll<HTMLElement>('a[href*="siplinx-ai.vercel.app/download"]').forEach((el) => {
      el.addEventListener('click', handleDlClick as EventListener);
    });
  </script>
</Layout>
