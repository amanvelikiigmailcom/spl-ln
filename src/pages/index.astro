---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';

const metadata = {
  title: 'Siplinx AI - AI Meeting Notes That Stay Private',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Offer banner - top of page -->
  <div class="bg-gradient-to-r from-blue-600 to-violet-600 text-white py-3 px-4 text-center text-sm font-medium">
    🎁 Sign in with Google and get started free - no credit card required
  </div>

  <!-- Hero Widget -->
  <Hero
    tagline="Sign in with Google, no credit card"
    actions={[
      {
        variant: 'primary',
        text: 'Start Free',
        href: 'https://siplinx-ai.vercel.app/download',
        icon: 'tabler:download',
        class: 'hero-btn-mac',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1611532736597-de2d4265fba3?auto=format&fit=crop&w=2070&q=80',
      alt: 'Siplinx AI meeting notes dashboard',
    }}
  >
    <Fragment slot="title">
      Your AI meeting companion<br />
      <span class="bg-gradient-to-r from-blue-500 to-violet-600 bg-clip-text text-transparent"
        >that never leaves your device</span
      >
    </Fragment>

    <Fragment slot="subtitle">
      Siplinx AI transcribes your meetings locally - your audio never leaves your device. Summaries and action items are
      generated by a powerful AI and delivered instantly.
      <strong>No bots in calls. No data leaks.</strong>
    </Fragment>

    <Fragment slot="bg">
      <div
        class="absolute inset-0 bg-gradient-to-br from-blue-50 via-white to-violet-50 dark:from-[#06051A] dark:via-[#060512] dark:to-[#0A0618]"
      >
      </div>
    </Fragment>
  </Hero>

  <!-- Note Widget -->
  <Note
    title="Works with:"
    description="Zoom · Google Meet · Microsoft Teams · Webex · Slack Huddles · In-person meetings"
  />

  <!-- Features Widget -->
  <Features
    id="features"
    tagline="Why Siplinx AI"
    title="Everything your meetings deserve"
    subtitle="Transcription runs locally on your device. Summaries are crafted by a powerful AI - fast, accurate, and ready when the meeting ends."
    items={[
      {
        title: 'Real-time Transcription (Local)',
        description:
          'A local speech-to-text model runs on your machine and converts speech to text in real time - zero latency, no audio upload, nothing leaves your device.',
        icon: 'tabler:microphone',
      },
      {
        title: 'Smart Summaries (High-Quality AI)',
        description:
          'Your transcript is processed by a high-quality AI that writes a clear, structured summary with key decisions and context - delivered in seconds.',
        icon: 'tabler:file-text-ai',
      },
      {
        title: 'Action Items Extraction',
        description:
          'Siplinx AI identifies tasks and commitments automatically. Never forget a follow-up, deadline, or decision again.',
        icon: 'tabler:list-check',
      },
      {
        title: 'Private by Design',
        description:
          'Your audio is transcribed locally - it never leaves your device. Summaries are generated from text only, with no recording ever shared.',
        icon: 'tabler:shield-lock',
      },
      {
        title: 'Multi-Platform Support',
        description:
          'Works with Zoom, Google Meet, Microsoft Teams, Webex, and any audio source on your Mac or Windows PC.',
        icon: 'tabler:apps',
      },
      {
        title: 'Instant Search & Export',
        description:
          'Search across all your meeting notes instantly. Export to Notion, Markdown, PDF, or your favorite productivity tool.',
        icon: 'tabler:search',
      },
    ]}
  />

  <!-- Steps Widget (How it Works) -->
  <Steps
    id="how-it-works"
    title="Get perfect meeting notes in 3 simple steps"
    items={[
      {
        title: 'Step 1: <span class="font-medium">Download & Install</span>',
        description:
          'Download Siplinx AI for Mac or Windows. The installer sets up the local transcription model on your machine - takes under 5 minutes.',
        icon: 'tabler:download',
      },
      {
        title: 'Step 2: <span class="font-medium">Join Your Meeting</span>',
        description:
          'Start any meeting on Zoom, Google Meet, Teams, or any platform. Siplinx AI automatically detects audio and begins transcribing locally.',
        icon: 'tabler:video',
      },
      {
        title: 'Step 3: <span class="font-medium">Get Your Notes</span>',
        description:
          'When the meeting ends, your notes are ready: full transcript, smart summary, action items, and key decisions - clear and structured.',
        icon: 'tabler:notes',
      },
      {
        title: 'Done! Focus on the conversation.',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=2070&q=80',
      alt: 'Siplinx AI in action',
    }}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-gradient-to-b from-blue-50 to-white dark:from-[#06051A] dark:to-transparent">
      </div>
    </Fragment>
  </Steps>

  <!-- Testimonials Widget -->
  <Testimonials
    title="Loved by teams who value privacy"
    subtitle="Join professionals who've upgraded their meeting workflow with Siplinx AI."
    testimonials={[
      {
        testimonial:
          'Siplinx AI changed how our team runs meetings. The summaries are spot-on and the fact that nothing goes to the cloud is a huge deal for our legal team.',
        name: 'Sarah Chen',
        job: 'Head of Operations, TechCorp',
        image: {
          src: 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=200&h=200&fit=crop',
          alt: 'Sarah Chen',
        },
      },
      {
        testimonial:
          'I stopped taking notes in meetings entirely. Siplinx AI handles everything - and the action item extraction saves me at least an hour every day.',
        name: 'Marcus Rodriguez',
        job: 'Product Manager, Startupify',
        image: {
          src: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=200&h=200&fit=crop',
          alt: 'Marcus Rodriguez',
        },
      },
      {
        testimonial:
          'As a consultant working with multiple clients, I needed something private. Siplinx AI is the only tool I trust - local processing is a game-changer.',
        name: 'Priya Patel',
        job: 'Independent Consultant',
        image: {
          src: 'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=200&h=200&fit=crop',
          alt: 'Priya Patel',
        },
      },
    ]}
  >
    <Fragment slot="bg">
      <div
        class="absolute inset-0 bg-gradient-to-b from-transparent via-blue-50 to-transparent dark:from-transparent dark:via-[#06051A]/50 dark:to-transparent"
      >
      </div>
    </Fragment>
  </Testimonials>

  <!-- FAQs Widget -->
  <FAQs
    title="Frequently Asked Questions"
    subtitle="Everything you need to know about Siplinx AI."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'How does Siplinx AI protect my privacy?',
        description:
          'Siplinx AI transcribes your meetings using a local model on your machine - your audio never leaves your device. Summaries are generated from the transcript text by a high-quality AI, with no recording ever shared.',
      },
      {
        title: 'How does the free trial work?',
        description:
          'Download and install Siplinx AI - no credit card needed. Use promo code TRIAL7 at checkout for 100% off your trial. After the trial ends, choose a paid plan to continue or your subscription ends.',
      },
      {
        title: 'Which meeting platforms does Siplinx AI support?',
        description:
          'Siplinx AI works with any application that uses your microphone or speaker output - including Zoom, Google Meet, Microsoft Teams, Webex, Slack Huddles, and in-person meetings.',
      },
      {
        title: 'What are the system requirements?',
        description:
          'For Mac: macOS 12 (Monterey) or later, Apple Silicon or Intel, 8GB RAM minimum. For Windows: Windows 10/11 (64-bit), 8GB RAM minimum, 4GB free storage for local models.',
      },
      {
        title: 'Do the local AI models need internet to work?',
        description:
          'Transcription is fully offline - the local STT model runs without internet. Summaries require a brief connection to process the transcript text. Your audio is never sent anywhere.',
      },
      {
        title: 'Can I export my meeting notes?',
        description:
          'Yes! Export to Markdown, PDF, Notion, Obsidian, Microsoft Word, or copy to clipboard. All exports happen locally - your data never touches our servers.',
      },
    ]}
  />

  <!-- CallToAction Widget -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Start Free',
        href: 'https://siplinx-ai.vercel.app/download',
        icon: 'tabler:download',
        class: 'cta-btn-mac',
      },
    ]}
  >
    <Fragment slot="title"> Start free </Fragment>

    <Fragment slot="subtitle">
      Sign in with Google - download starts instantly. <br class="hidden md:inline" />
      No credit card. No cloud. Your meetings stay private - always.
    </Fragment>

    <Fragment slot="bg">
      <div
        class="absolute inset-0 bg-gradient-to-br from-blue-600 via-blue-700 to-violet-700 dark:from-blue-900 dark:via-blue-950 dark:to-violet-950"
      >
      </div>
    </Fragment>
  </CallToAction>

  <script>
    // Auth flow: if not signed in → Google auth → /welcome → download
    function handleDownloadClick(this: HTMLElement, e: MouseEvent) {
      e.preventDefault();
      const cls = (this as HTMLElement).className || '';
      const loc = cls.includes('hero') ? 'hero' : cls.includes('cta') ? 'cta' : 'other';
      const ph = (window as unknown as Record<string, unknown>).__ph as ((ev: string, p?: Record<string, unknown>) => void) | undefined;
      ph?.('trial_click', { location: loc, lang: 'en', page: '/' });
      ph?.('auth_start', { location: loc, lang: 'en', page: '/' });
      const redirect = encodeURIComponent('https://siplinx-ai.vercel.app/download');
      window.location.href = `https://siplinx-ai.vercel.app/web/start?redirect=${redirect}`;
    }

    function attachAuthToButtons() {
      const selectors = ['.hero-btn-mac', '.cta-btn-mac'];
      selectors.forEach((sel) => {
        document.querySelectorAll<HTMLElement>(sel).forEach((el) => {
          el.addEventListener('click', handleDownloadClick);
        });
      });
    }

    attachAuthToButtons();
    document.addEventListener('astro:page-load', attachAuthToButtons);
  </script>
</Layout>
