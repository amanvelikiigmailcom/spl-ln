---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Получить Siplinx AI - Приватные заметки на встречах за $2/неделю',
  description:
    'Скачайте Siplinx AI и получайте AI-заметки на встречах, которые работают 100% на вашем устройстве. Без облака. Всего $2 в неделю.',
  robots: { index: false, follow: false },
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <section class="relative py-20 md:py-28 overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-br from-blue-50 via-white to-violet-50 dark:from-[#06051A] dark:via-[#060512] dark:to-[#0A0618]"
    >
    </div>
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-blue-400/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-violet-400/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <div
        class="inline-flex items-center gap-2 mb-6 px-4 py-1.5 rounded-full bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 text-sm font-semibold"
      >
        <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
        Доступно для Mac и Windows
      </div>

      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-gray-900 dark:text-white mb-6 leading-tight">
        AI-заметки на встречах,<br />
        <span class="bg-gradient-to-r from-blue-500 to-violet-600 bg-clip-text text-transparent"
          >которые не покидают устройство</span
        >
      </h1>

      <p class="text-xl text-gray-600 dark:text-slate-300 mb-4 max-w-2xl mx-auto">
        Siplinx AI транскрибирует встречи локально - ваше аудио никогда не покидает устройство. Резюме и задачи
        формирует качественный AI и доставляет мгновенно. Никаких ботов в звонках. Никаких утечек данных.
      </p>

      <p class="text-base text-gray-500 dark:text-slate-400 mb-10">
        Работает с Zoom, Google Meet и Microsoft Teams. Всего <strong class="text-gray-700 dark:text-white"
          >$2/неделю</strong
        >.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          href="https://siplinx-ai.vercel.app/download?variant=direct"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-gradient-to-r from-blue-600 to-violet-600 text-white font-bold text-lg shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-200"
          id="btn-mac"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
            ></path>
          </svg>
          <span id="dl-label">Скачать для Mac</span>
        </a>
        <a
          href="https://siplinx-ai.vercel.app/download?variant=direct"
          class="text-sm text-gray-500 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
        >
          Также доступно для Windows →
        </a>
      </div>

      <p class="mt-4 text-xs text-gray-400 dark:text-slate-500">
        Без пробного периода. Без промокода. Просто скачайте и работайте.
      </p>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 max-w-5xl mx-auto px-4 sm:px-6">
    <div class="grid md:grid-cols-3 gap-8">
      <div class="text-center p-6">
        <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-blue-100 dark:bg-blue-900/40 flex items-center justify-center">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6 text-blue-600 dark:text-blue-400"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"
            ></path>
          </svg>
        </div>
        <h3 class="font-bold text-gray-900 dark:text-white mb-2">Транскрипция в реальном времени</h3>
        <p class="text-sm text-gray-500 dark:text-slate-400">
          Локальная модель речи работает на вашем компьютере. Без загрузки аудио. Без ожидания. Результат появляется по
          ходу разговора.
        </p>
      </div>

      <div class="text-center p-6">
        <div
          class="w-12 h-12 mx-auto mb-4 rounded-xl bg-violet-100 dark:bg-violet-900/40 flex items-center justify-center"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6 text-violet-600 dark:text-violet-400"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
            ></path>
          </svg>
        </div>
        <h3 class="font-bold text-gray-900 dark:text-white mb-2">Умные резюме и задачи</h3>
        <p class="text-sm text-gray-500 dark:text-slate-400">
          Качественный AI читает транскрипт и формирует чистое резюме с ключевыми решениями и задачами. Готово за
          секунды.
        </p>
      </div>

      <div class="text-center p-6">
        <div
          class="w-12 h-12 mx-auto mb-4 rounded-xl bg-green-100 dark:bg-green-900/40 flex items-center justify-center"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6 text-green-600 dark:text-green-400"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
            ></path>
          </svg>
        </div>
        <h3 class="font-bold text-gray-900 dark:text-white mb-2">Приватность по умолчанию</h3>
        <p class="text-sm text-gray-500 dark:text-slate-400">
          Ваше аудио транскрибируется локально и никогда не покидает устройство. Резюме создаётся только из текста -
          запись никуда не отправляется. Никаких ботов в звонках.
        </p>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 bg-gray-50 dark:bg-slate-900/50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-bold text-center text-gray-900 dark:text-white mb-12">Готово за 5 минут</h2>
      <div class="space-y-8">
        {
          [
            {
              n: '1',
              title: 'Скачайте и установите',
              text: 'Запустите установщик на Mac или Windows. Локальные AI-модели настраиваются автоматически при установке.',
            },
            {
              n: '2',
              title: 'Войдите на встречу',
              text: 'Откройте Zoom, Google Meet или Teams как обычно. Siplinx AI определит аудио и начнёт транскрипцию на вашем устройстве.',
            },
            {
              n: '3',
              title: 'Получите заметки',
              text: 'Когда встреча закончится, заметки уже готовы: транскрипт, резюме, задачи. Всё создано локально, готово к отправке.',
            },
          ].map((step) => (
            <div class="flex gap-6 items-start">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-violet-600 text-white font-bold flex items-center justify-center text-sm">
                {step.n}
              </div>
              <div>
                <h3 class="font-bold text-gray-900 dark:text-white mb-1">{step.title}</h3>
                <p class="text-gray-500 dark:text-slate-400 text-sm">{step.text}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Comparison -->
  <section class="py-16 max-w-3xl mx-auto px-4 sm:px-6">
    <h2 class="text-2xl font-bold text-center text-gray-900 dark:text-white mb-10">Почему не Granola или Fireflies?</h2>
    <div class="overflow-x-auto rounded-2xl border border-gray-100 dark:border-slate-800">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 dark:bg-slate-900/60">
            <th class="text-left px-6 py-4 font-semibold text-gray-700 dark:text-slate-300"></th>
            <th class="px-6 py-4 font-bold text-blue-600 dark:text-blue-400">Siplinx AI</th>
            <th class="px-6 py-4 font-semibold text-gray-500 dark:text-slate-400">Granola / Fireflies</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-slate-800">
          {
            [
              ['Аудио отправляется в облако', 'Никогда', 'Всегда'],
              ['Бот присоединяется к звонку', 'Нет', 'Да'],
              ['Работает офлайн', 'Да', 'Нет'],
              ['Совместимо с HIPAA', 'Да', 'Зависит'],
              ['Цена', '$2/неделю', '$18+/мес'],
            ].map(([feature, siplinx, other]) => (
              <tr class="hover:bg-gray-50 dark:hover:bg-slate-900/30 transition-colors">
                <td class="px-6 py-4 text-gray-600 dark:text-slate-400">{feature}</td>
                <td class="px-6 py-4 text-center font-semibold text-green-600 dark:text-green-400">{siplinx}</td>
                <td class="px-6 py-4 text-center text-gray-400 dark:text-slate-500">{other}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-blue-600 to-violet-700 dark:from-blue-800 dark:to-violet-900">
    </div>
    <div class="relative max-w-2xl mx-auto px-4 sm:px-6 text-center text-white">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Готовы попробовать?</h2>
      <p class="text-blue-100 mb-8 text-lg">
        Скачайте Siplinx AI прямо сейчас. Первые заметки будут готовы через несколько минут.
      </p>
      <a
        href="https://siplinx-ai.vercel.app/download?variant=direct"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-white text-blue-700 font-bold text-lg shadow-lg hover:scale-105 transition-all duration-200"
      >
        Скачать Siplinx AI - $2/неделю
      </a>
      <p class="mt-4 text-sm text-blue-200">Без облачного аккаунта. Без обязательной подписки для старта.</p>
    </div>
  </section>
</Layout>

<script>
  const label = document.getElementById('dl-label');
  if (label) {
    const isWin = navigator.userAgent.includes('Windows');
    if (isWin) label.textContent = 'Скачать для Windows';
  }

  // Auth flow: Google → /welcome?variant=direct → скачивание
  function handleGetDownloadClick(e: MouseEvent) {
    e.preventDefault();
    const ph = (window as unknown as Record<string, unknown>).__ph as ((ev: string, p?: Record<string, unknown>) => void) | undefined;
    ph?.('get_cta_click', { lang: 'ru', page: '/ru/get/', variant: 'direct' });
    ph?.('google_signin_click', { lang: 'ru', page: '/ru/get/', variant: 'direct' });
    ph?.('auth_start', { location: 'get_page', lang: 'ru', variant: 'direct' });
    const redirect = encodeURIComponent('https://siplinx-ai.vercel.app/download?variant=direct');
    window.location.href = `https://siplinx-ai.vercel.app/web/start?redirect=${redirect}`;
  }

  document.querySelectorAll<HTMLElement>('a[href*="siplinx-ai.vercel.app/download"]').forEach((el) => {
    el.addEventListener('click', handleGetDownloadClick as EventListener);
  });
</script>
