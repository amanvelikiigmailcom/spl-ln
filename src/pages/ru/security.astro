---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Безопасность и конфиденциальность - Siplinx AI',
  description:
    'Как Siplinx AI обеспечивает 100% приватность ваших встреч. Локальные LLM и STT модели работают на вашем устройстве. Данные никуда не уходят.',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <section class="relative not-prose overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-br from-blue-50 via-white to-violet-50 dark:from-[#06051A] dark:via-[#060512] dark:to-[#0A0618]"
    >
    </div>
    <div class="absolute orb orb-blue w-72 h-72 top-10 -left-20"></div>
    <div class="absolute orb orb-violet w-64 h-64 bottom-10 -right-16"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center py-12 md:py-16">
      <div
        class="inline-flex items-center gap-2 bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-300 rounded-full px-4 py-1.5 text-sm font-semibold mb-6"
      >
        <span class="w-2 h-2 rounded-full bg-green-500 inline-block animate-pulse"></span>
        100% локальная обработка
      </div>
      <h1 class="text-5xl md:text-6xl font-bold tracking-tight text-gray-900 dark:text-white mb-6" data-delay="100">
        Ваши встречи никогда<br />
        <span class="gradient-animate">не покидают устройство</span>
      </h1>
      <p class="text-xl text-gray-600 dark:text-slate-300 max-w-2xl mx-auto" data-delay="200">
        Siplinx AI построен на простом обещании: аудио, транскрипты и заметки ваших встреч обрабатываются исключительно
        на вашем устройстве. Никакого облака, никаких серверов, без исключений.
      </p>
    </div>
  </section>

  <!-- Core stats -->
  <section class="py-16 bg-white dark:bg-[#060512] border-y border-gray-100 dark:border-slate-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        {
          [
            {
              icon: '🖥️',
              stat: '0 байт',
              label: 'Отправлено на наши серверы',
              desc: 'Аудио, транскрипты и заметки никогда не покидают ваш компьютер. У нас нет серверов, получающих данные ваших встреч.',
            },
            {
              icon: '📡',
              stat: 'Офлайн',
              label: 'Работает без интернета',
              desc: 'После установки AI-моделей Siplinx AI работает полностью в автономном режиме. Wi-Fi не нужен.',
            },
            {
              icon: '🔑',
              stat: 'Локально',
              label: 'AI-модели на вашем устройстве',
              desc: 'LLM и STT модели устанавливаются прямо на ваш Mac или Windows PC - без обращения к удалённому API.',
            },
          ].map((item, i) => (
            <div class="reveal-scale px-4" data-delay={i * 120}>
              <div class="text-4xl mb-3">{item.icon}</div>
              <div class="text-4xl font-black bg-gradient-to-r from-blue-600 to-violet-600 bg-clip-text text-transparent mb-1">
                {item.stat}
              </div>
              <div class="font-bold text-gray-900 dark:text-white mb-2">{item.label}</div>
              <p class="text-sm text-gray-600 dark:text-slate-400 leading-relaxed">{item.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-20 max-w-5xl mx-auto px-4 sm:px-6">
    <h2 class="reveal text-3xl font-bold text-gray-900 dark:text-white text-center mb-14">
      Как работает локальная обработка
    </h2>
    <div class="space-y-5">
      {
        [
          {
            step: '01',
            title: 'AI-модели устанавливаются локально при первом запуске',
            body: 'При первой установке Siplinx AI приложение загружает LLM (языковую модель) и STT (распознавание речи) модели прямо на ваше устройство. После этого никакой удалённый AI-сервис не вызывается.',
            color: 'blue',
          },
          {
            step: '02',
            title: 'Аудио захватывается и обрабатывается на устройстве',
            body: 'Во время встречи Siplinx AI захватывает системный аудиопоток локально через OS Audio API. Он немедленно передаётся в локальную STT-модель - не касаясь сетевого сокета.',
            color: 'violet',
          },
          {
            step: '03',
            title: 'Транскрипция выполняется в реальном времени на CPU/GPU',
            body: 'Локальная модель на основе Whisper преобразует речь в текст на вашем оборудовании. На Apple Silicon используется Neural Engine. На Windows модель работает на CPU или GPU с аппаратным ускорением.',
            color: 'blue',
          },
          {
            step: '04',
            title: 'Резюме и задачи генерируются локально',
            body: 'По окончании встречи локальная LLM читает транскрипт и генерирует резюме, ключевые решения и задачи. Модель работает целиком в вашей RAM - никаких API-вызовов, никакой задержки ожидания облака.',
            color: 'violet',
          },
          {
            step: '05',
            title: 'Заметки сохраняются только на локальный диск',
            body: 'Все транскрипты, резюме и задачи хранятся в зашифрованной локальной базе данных на вашем компьютере. Вы сами контролируете, где хранятся, экспортируются или удаляются заметки.',
            color: 'blue',
          },
        ].map((item, i) => (
          <div
            class="reveal card-hover flex gap-6 bg-white dark:bg-slate-900/50 border border-gray-100 dark:border-slate-800 rounded-xl p-6"
            data-delay={i * 80}
          >
            <div
              class={`flex-shrink-0 w-12 h-12 rounded-xl flex items-center justify-center font-black text-sm ${item.color === 'blue' ? 'bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300' : 'bg-violet-100 dark:bg-violet-900/40 text-violet-700 dark:text-violet-300'}`}
            >
              {item.step}
            </div>
            <div>
              <h3 class="font-bold text-gray-900 dark:text-white mb-1">{item.title}</h3>
              <p class="text-gray-600 dark:text-slate-300 text-sm leading-relaxed">{item.body}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- What we don't collect -->
  <section class="py-16 bg-white dark:bg-[#060512] border-y border-gray-100 dark:border-slate-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="reveal text-3xl font-bold text-gray-900 dark:text-white text-center mb-10">
        Что мы никогда не собираем
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {
          [
            'Аудиозаписи встреч',
            'Транскрипты и текст разговоров',
            'AI-резюме и заметки',
            'Имена участников встреч',
            'Имена файлов, проектов и клиентов',
            'Содержимое экрана и заголовки окон',
            'Метаданные платформ встреч',
            'Биометрические и голосовые данные',
          ].map((item, i) => (
            <div
              class="reveal card-hover flex items-center gap-3 bg-red-50 dark:bg-red-950/30 border border-red-100 dark:border-red-900/50 rounded-lg px-4 py-3"
              data-delay={i * 60}
            >
              <svg
                class="w-5 h-5 text-red-500 flex-shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
              <span class="text-sm font-medium text-gray-700 dark:text-slate-300">{item}</span>
            </div>
          ))
        }
      </div>
      <p class="text-center text-sm text-gray-500 dark:text-slate-500 mt-6">
        На наших серверах хранятся только ваш email аккаунта и статус подписки - ничего из содержимого ваших встреч.
      </p>
    </div>
  </section>

  <!-- Compliance -->
  <section class="py-20 max-w-5xl mx-auto px-4 sm:px-6">
    <h2 class="reveal text-3xl font-bold text-gray-900 dark:text-white text-center mb-10">Соответствие стандартам</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-12">
      {
        [
          { label: 'GDPR', icon: '🇪🇺', desc: 'Никаких персональных данных на наших серверах - по архитектуре.' },
          {
            label: 'HIPAA',
            icon: '🏥',
            desc: 'Идеально для медицинских команд, работающих с конфиденциальными обсуждениями.',
          },
          { label: 'SOC 2', icon: '🛡️', desc: 'Аудит SOC 2 Type II в процессе.' },
          { label: 'Изолированная сеть', icon: '✈️', desc: 'Работает без сети - подходит для режима air-gap.' },
        ].map((b, i) => (
          <div
            class="reveal-scale card-hover bg-white dark:bg-slate-900/50 border border-gray-100 dark:border-slate-800 rounded-xl p-5 text-center"
            data-delay={i * 100}
          >
            <div class="text-3xl mb-2">{b.icon}</div>
            <div class="font-bold text-gray-900 dark:text-white text-sm mb-1">{b.label}</div>
            <p class="text-xs text-gray-500 dark:text-slate-500">{b.desc}</p>
          </div>
        ))
      }
    </div>

    <div
      class="reveal bg-gradient-to-br from-blue-50 to-violet-50 dark:from-blue-950/40 dark:to-violet-950/40 border border-blue-100 dark:border-blue-900/50 rounded-2xl p-8 text-center"
    >
      <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Нашли уязвимость?</h3>
      <p class="text-gray-600 dark:text-slate-300 mb-5 text-sm">
        Мы серьёзно относимся к отчётам о безопасности. Сообщите ответственно - мы ответим в течение 48 часов.
      </p>
      <a
        href="https://t.me/amanyessen"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-shimmer inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-gradient-to-r from-blue-600 to-violet-600 text-white font-semibold hover:from-blue-700 hover:to-violet-700 transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5 duration-200"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L6.922 14.06l-2.962-.924c-.643-.204-.657-.643.136-.953l11.57-4.46c.537-.194 1.006.131.828.498z"
          ></path>
        </svg>
        Написать в Telegram
      </a>
    </div>
  </section>
</Layout>
