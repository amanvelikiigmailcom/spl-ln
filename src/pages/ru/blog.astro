---
import Layout from '~/layouts/PageLayout.astro';
import { fetchPosts } from '~/utils/blog';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Блог - Siplinx AI',
  description:
    'Статьи о приватных AI-заметках на встречах, локальных языковых моделях, конфиденциальности данных и продуктивности команд.',
};

const posts = (await fetchPosts()).filter((p) => p.slug.startsWith('ru/'));
---

<Layout metadata={metadata}>
  <section class="relative py-20 md:py-24 overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-br from-blue-50 via-white to-violet-50 dark:from-[#06051A] dark:via-[#060512] dark:to-[#0A0618]"
    >
    </div>
    <div class="absolute orb orb-blue w-52 h-52 -top-10 -left-10"></div>
    <div class="absolute orb orb-violet w-44 h-44 -bottom-8 -right-8"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="reveal text-sm font-bold uppercase tracking-widest text-blue-600 dark:text-blue-400 mb-4">Блог</p>
      <h1
        class="reveal text-4xl md:text-5xl font-bold tracking-tight text-gray-900 dark:text-white mb-4"
        data-delay="80"
      >
        Insights по AI и конфиденциальности
      </h1>
      <p class="reveal text-lg text-gray-500 dark:text-slate-400 max-w-2xl mx-auto" data-delay="160">
        Руководства, сравнения и стратегии по AI-заметкам, приватной обработке данных и продуктивным встречам.
      </p>
    </div>
  </section>

  <section class="py-12 max-w-4xl mx-auto px-4 sm:px-6">
    <div class="grid gap-8 sm:grid-cols-2">
      {
        posts.map((post, i) => (
          <article
            class={`reveal card-hover bg-white dark:bg-slate-900/50 border border-gray-100 dark:border-slate-800 rounded-2xl overflow-hidden`}
            data-delay={i * 100}
          >
            {post.image && (
              <a href={getPermalink(post.permalink, 'post')}>
                <img src={post.image} alt={post.title} class="w-full h-48 object-cover" loading="lazy" />
              </a>
            )}
            <div class="p-6">
              {post.category && (
                <span class="inline-block mb-3 text-xs font-bold uppercase tracking-widest text-blue-600 dark:text-blue-400">
                  {typeof post.category === 'string' ? post.category : post.category.title}
                </span>
              )}
              <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-2 leading-snug">
                <a
                  href={getPermalink(post.permalink, 'post')}
                  class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
                >
                  {post.title}
                </a>
              </h2>
              {post.excerpt && (
                <p class="text-sm text-gray-600 dark:text-slate-400 leading-relaxed mb-4">{post.excerpt}</p>
              )}
              <a
                href={getPermalink(post.permalink, 'post')}
                class="text-sm font-semibold text-blue-600 dark:text-blue-400 hover:underline"
              >
                Читать статью →
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</Layout>
