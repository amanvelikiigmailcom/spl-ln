---
import Layout from '~/layouts/PageLayout.astro';
import { authors } from '~/data/authors';

export const prerender = true;

const metadata = {
  title: 'Authors - Siplinx AI',
  description:
    'Meet the team and advisors who write for Siplinx AI - experts in AI, privacy, and meeting productivity.',
  robots: { index: true, follow: true },
};
---

<Layout metadata={metadata}>
  <section class="relative not-prose overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-br from-blue-50 via-white to-violet-50 dark:from-[#06051A] dark:via-[#060512] dark:to-[#0A0618]"
    >
    </div>
    <div class="absolute orb orb-blue w-60 h-60 -top-10 -left-12"></div>
    <div class="absolute orb orb-violet w-52 h-52 -bottom-8 -right-10"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center py-12 md:py-16">
      <p class="text-sm font-bold uppercase tracking-widest text-blue-600 dark:text-blue-400 mb-4">Our Team</p>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-gray-900 dark:text-white mb-6">
        The people behind Siplinx AI
      </h1>
      <p class="text-xl text-gray-600 dark:text-slate-300 max-w-2xl mx-auto">
        Articles on privacy, AI, and meeting productivity - written by professionals who use these tools in real work.
      </p>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        authors.map((author) => (
          <a
            href={`/authors/${author.slug}/`}
            class="group block bg-white dark:bg-slate-800 rounded-2xl shadow-sm hover:shadow-md transition-shadow border border-gray-100 dark:border-slate-700 overflow-hidden"
          >
            <div class="aspect-square overflow-hidden bg-gradient-to-br from-blue-100 to-violet-100 dark:from-blue-900 dark:to-violet-900">
              <img
                src={author.photo}
                alt={author.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                onerror="this.style.display='none'"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-1">{author.name}</h2>
              <p class="text-sm text-blue-600 dark:text-blue-400 font-medium mb-3">{author.role}</p>
              <div class="flex flex-wrap gap-1.5">
                {author.expertise.slice(0, 3).map((tag) => (
                  <span class="inline-block text-xs px-2 py-0.5 rounded-full bg-blue-50 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 border border-blue-100 dark:border-blue-800">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      name: 'Siplinx AI Authors',
      itemListElement: authors.map((a, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        url: `https://siplinx.com/authors/${a.slug}/`,
        name: a.name,
      })),
    })}
  />
</Layout>
